apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Chart.Name }}-db
  labels:
    app.kubernetes.io/name: {{ .Chart.Name }}-db
    app.kubernetes.io/part-of: {{ .Chart.Name }}
    app.kubernetes.io/component: database
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ .Chart.Name }}-db
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ .Chart.Name }}-db
        app.kubernetes.io/part-of: {{ .Chart.Name }}
        app.kubernetes.io/component: database
    spec:
      automountServiceAccountToken: false
      containers:
        - name: postgres
          image: "{{ .Values.image.postgres.repository }}:{{ .Values.image.postgres.tag }}"
          ports:
            - containerPort: 5432
              protocol: TCP
          envFrom:
            - secretRef:
                name: {{ .Chart.Name }}-db-secret
          volumeMounts:
            - name: db-storage
              mountPath: /var/lib/postgresql/data
              subPath: pgdata
          resources:
            requests:
              cpu: 250m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
            runAsNonRoot: false
          livenessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ .Values.database.user }}", "-d", "{{ .Values.database.dbName }}"]
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ .Values.database.user }}", "-d", "{{ .Values.database.dbName }}"]
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: 3
      volumes:
        - name: db-storage
          persistentVolumeClaim:
            claimName: {{ .Chart.Name }}-db-pvc
